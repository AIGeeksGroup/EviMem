# ────────────────────────────────────────────────────────────────────
# Python
# ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# ────────────────────────────────────────────────────────────────────
# API keys / secrets — NEVER commit these
# ────────────────────────────────────────────────────────────────────
api_keys.txt
api_keys_backup.txt
.env
.env.*
*.key
*.pem
secrets.json
config.local.json

# ────────────────────────────────────────────────────────────────────
