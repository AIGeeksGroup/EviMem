# ────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
cache/
mirix_dbs/

# ────────────────────────────────────────────────────────────────────
# Experiment outputs
# ────────────────────────────────────────────────────────────────────
results/
allresults/
output/
*.log
*.out
*.err

# ────────────────────────────────────────────────────────────────────
# Virtual environments
# ────────────────────────────────────────────────────────────────────
venv/
env/
.venv/
.virtualenv/
ENV/

# ────────────────────────────────────────────────────────────────────
# IDE / editor
# ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# ────────────────────────────────────────────────────────────────────
