# ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────────────────────────────────
# Jupyter / IPython
# ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

